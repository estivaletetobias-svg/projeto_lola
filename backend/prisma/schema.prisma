generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  CFO
  HR_ADMIN
  HR_USER
  VIEWER
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SnapshotStatus {
  PENDING
  VALIDATING
  MAPPING
  CALCULATING
  READY
  ERROR
}

model Tenant {
  id             String      @id @default(uuid())
  name           String
  cnpj           String?
  cnae           String?
  company_size   String?     // bucket: 0-50, 51-200, etc.
  city           String?
  state          String?
  country        String?
  currency       String      @default("BRL")
  area_weights   Json?       // JSON with strategic weights per area
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  
  users            User[]
  snapshots        PayrollSnapshot[]
  employees        Employee[]
  merit_cycles     MeritCycle[]
  diagnostics      CompanyDiagnostic[]
  area_diagnostics AreaDiagnostic[]
  audit_events     AuditEvent[]

  @@map("tenants")
}

model User {
  id         String   @id @default(uuid())
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id])
  email      String   @unique
  role       Role     @default(HR_USER)
  created_at DateTime @default(now())

  audit_events AuditEvent[]

  @@map("users")
}

model PayrollSnapshot {
  id          String         @id @default(uuid())
  tenant_id   String
  tenant      Tenant         @relation(fields: [tenant_id], references: [id])
  period_date DateTime
  source_type String         // e.g. "CSV", "XLSX"
  s3_file_key String
  status      SnapshotStatus @default(PENDING)
  created_at  DateTime       @default(now())

  import_jobs      PayrollImportJob[]
  compensation     Compensation[]
  job_matches      JobMatch[]
  diagnostics      CompanyDiagnostic[]
  area_diagnostics AreaDiagnostic[]
  merit_cycles     MeritCycle[]

  @@map("payroll_snapshots")
}

model PayrollImportJob {
  id          String    @id @default(uuid())
  snapshot_id String
  snapshot    PayrollSnapshot @relation(fields: [snapshot_id], references: [id])
  status      JobStatus @default(PENDING)
  started_at  DateTime?
  finished_at DateTime?
  error_log   Json?     // error_log_json

  @@map("payroll_import_jobs")
}

model Employee {
  id             String    @id @default(uuid())
  tenant_id      String
  tenant         Tenant    @relation(fields: [tenant_id], references: [id])
  employee_key   String    // identifying code internal to tenant
  full_name      String?   // masked maybe
  area           String
  location_city  String?
  location_state String?
  status         String?   // ACTIVE, TERMINATED
  hired_at       DateTime?
  terminated_at  DateTime?
  created_at     DateTime  @default(now())

  compensation         Compensation[]
  job_matches          JobMatch[]
  merit_recommendations MeritRecommendation[]

  @@unique([tenant_id, employee_key])
  @@map("employees")
}

model Compensation {
  id             String   @id @default(uuid())
  employee_id    String
  employee       Employee @relation(fields: [employee_id], references: [id])
  snapshot_id    String
  snapshot       PayrollSnapshot @relation(fields: [snapshot_id], references: [id])
  base_salary    Float
  benefits_value Float    @default(0)
  variable_value Float    @default(0)
  overtime_value Float    @default(0)
  total_cash     Float
  currency       String   @default("BRL")
  created_at     DateTime @default(now())

  @@map("compensation")
}

model JobCatalog {
  id               String   @id @default(uuid())
  family           String
  title_std        String
  level            String
  cbo_code         String?
  created_at       DateTime @default(now())

  job_matches      JobMatch[]
  market_benchmarks MarketBenchmark[]

  @@map("job_catalog")
}

model JobMatch {
  id                  String   @id @default(uuid())
  employee_id         String
  employee            Employee @relation(fields: [employee_id], references: [id])
  snapshot_id         String
  snapshot            PayrollSnapshot @relation(fields: [snapshot_id], references: [id])
  job_catalog_id      String
  job_catalog         JobCatalog @relation(fields: [job_catalog_id], references: [id])
  confidence          Float
  method              String   // e.g. "REGEX", "FUZZY", "AI"
  reviewed_by_user_id String?
  reviewed_at         DateTime?
  created_at          DateTime @default(now())

  @@map("job_matches")
}

model MarketBenchmark {
  id                  String     @id @default(uuid())
  job_catalog_id      String
  job_catalog         JobCatalog @relation(fields: [job_catalog_id], references: [id])
  cnae                String?
  company_size_bucket String?
  city                String?
  state               String?
  country             String?
  p25                 Float
  p50                 Float
  p75                 Float
  n                   Int
  as_of_date          DateTime
  source_tag          String?
  created_at          DateTime   @default(now())

  @@map("market_benchmarks")
}

model MacroIndex {
  id          String   @id @default(uuid())
  index_name  String
  period_date DateTime
  value       Float
  created_at  DateTime @default(now())

  @@map("macro_index")
}

model MeritCycle {
  id              String   @id @default(uuid())
  tenant_id       String
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  snapshot_id     String
  snapshot        PayrollSnapshot @relation(fields: [snapshot_id], references: [id])
  name            String
  budget_type     String   // e.g. "FIXED", "PERCENTAGE"
  budget_value    Float
  constraints     Json?    // teto, piso, etc.
  area_weights    Json?
  created_at      DateTime @default(now())

  recommendations MeritRecommendation[]

  @@map("merit_cycles")
}

model MeritRecommendation {
  id                    String     @id @default(uuid())
  merit_cycle_id        String
  merit_cycle           MeritCycle @relation(fields: [merit_cycle_id], references: [id])
  employee_id           String
  employee              Employee   @relation(fields: [employee_id], references: [id])
  action_type           String     // Merit, Promotion, Adjustment
  suggested_raise_value Float
  suggested_raise_percent Float
  new_total_cash        Float
  cost_monthly          Float
  cost_annual           Float
  rationale             Json?      // rationale_json
  created_at            DateTime   @default(now())

  @@map("merit_recommendations")
}

model CompanyDiagnostic {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  snapshot_id String
  snapshot    PayrollSnapshot @relation(fields: [snapshot_id], references: [id])
  metrics     Json
  created_at  DateTime @default(now())

  @@map("company_diagnostics")
}

model AreaDiagnostic {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  snapshot_id String
  snapshot    PayrollSnapshot @relation(fields: [snapshot_id], references: [id])
  area_name   String
  metrics     Json
  created_at  DateTime @default(now())

  @@map("area_diagnostics")
}

model AuditEvent {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id])
  entity_type String
  entity_id   String
  action      String
  metadata    Json?
  created_at  DateTime @default(now())

  @@map("audit_events")
}
